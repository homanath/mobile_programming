<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:stretchColumns="1"
    android:fitsSystemWindows="true"
    android:padding="16dp">

    <TableRow android:layout_marginBottom="10dp">
        <TextView android:text="Username: " android:textSize="16sp"/>
        <EditText android:hint="Enter name" android:inputType="text"/>
    </TableRow>

    <TableRow android:layout_marginBottom="10dp">
        <TextView android:text="Password: " android:textSize="16sp"/>
        <EditText android:hint="Enter password" android:inputType="textPassword"/>
    </TableRow>

    <TableRow>
        <Button
            android:text="Login Now"
            android:layout_span="2"/>
    </TableRow>

</TableLayout>